%%{init: {"theme": "neutral"}}%%
flowchart TB
  R0["One-shot prompt<br/><small>runs once, you watch</small>"]
  R1["/goal<br/><small>loops to a verifiable condition, then stops</small>"]
  R2["/loop (session)<br/><small>interval cron in your terminal; ends when you close it</small>"]
  R3["Routine / scheduled agent (cloud)<br/><small>runs on a cron even after you log off</small>"]
  R4["Automation pipeline<br/><small>CI / queue-triggered, fully unattended</small>"]
  R0 --> R1 --> R2 --> R3 --> R4
  L["more durable / less babysitting -->"]
  R0 -.-> L
  classDef rung fill:#eef2f7,stroke:#5b6b7b,stroke-width:2px,color:#1f2328;
  classDef axis fill:#ffffff,stroke:#ffffff,color:#5b6b7b;
  class R0,R1,R2,R3,R4 rung;
  class L axis;
